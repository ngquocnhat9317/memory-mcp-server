{
  "name": "@nhatnguyen9317/memory-mcp-server",
  "version": "1.1.5",
  "description": "MCP server for persisting agent long-term memory and step-by-step reasoning traces in SQLite",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/index.js",
    "dist/constants.js",
    "dist/db.js",
    "dist/migrations/*.js",
    "dist/schemas/*.js",
    "dist/tools/*.js",
    "dist/types.js",
    "dist/utils.js",
    "README.md",
    "GUIDELINES.md"
  ],
  "bin": {
    "memory-mcp-server": "dist/index.js"
  },
  "license": "MIT",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js','755')\"",
    "test": "npm run build && node --test dist/__tests__/*.test.js",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
